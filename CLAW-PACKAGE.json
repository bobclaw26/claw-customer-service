{
  "name": "claw-customer-service",
  "version": "1.0.0",
  "description": "AI-powered customer service automation platform built on OpenClaw",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "ts-node src/app.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "db:init": "sqlite3 claw-learning.db < src/services/learning/schema.sql"
  },
  "dependencies": {
    "express": "^4.18.2",
    "googleapis": "^118.0.0",
    "twilio": "^4.0.0",
    "better-sqlite3": "^9.0.0",
    "node-cache": "^5.1.2",
    "uuid": "^9.0.0",
    "node-fetch": "^3.3.0",
    "dotenv": "^16.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.17",
    "@types/better-sqlite3": "^7.6.4",
    "@types/uuid": "^9.0.2",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.1",
    "jest": "^29.5.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "prettier": "^2.8.0",
    "eslint": "^8.40.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0"
  }
}
